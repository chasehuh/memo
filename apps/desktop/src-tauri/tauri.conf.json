{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agentnote",
  "version": "0.1.0",
  "identifier": "com.chasehuh.agentnote",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://www.agentnote.dev"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "agentnote",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14.0,
          "y": 10.0
        },
        "userAgent": "agentnote-desktop"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Productivity",
    "shortDescription": "Minimal notepad next to the agent tab",
    "longDescription": "Thin macOS shell that loads the agentnote web app.",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
